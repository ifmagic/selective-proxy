{
  "manifest_version": 3,
  "name": "selective-proxy",
  "version": "1.2",
  "description": "Route specific domains through a custom proxy while letting all other traffic remain direct",
  "permissions": ["proxy", "storage", "tabs", "webNavigation"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  }
}