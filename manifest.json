{
  "manifest_version": 3,
  "name": "selective-proxy",
  "version": "1.1",
  "description": "Route specific domains through a custom proxy while letting all other traffic remain direct",
  "permissions": ["proxy", "storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.svg"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}